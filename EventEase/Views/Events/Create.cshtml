@model EventEase.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<h2>Create Event</h2>

<form asp-action="Create">
    <div class="form-group">
        <label asp-for="EventName"></label>
        <input asp-for="EventName" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" class="form-control" type="datetime-local" />
    </div>
    <div class="form-group">
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" class="form-control" type="datetime-local" />
    </div>
    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="form-group">
        <label asp-for="ImageUrl"></label>
        <input asp-for="ImageUrl" class="form-control" id="imageUrlInput" oninput="previewImage(this.value)" />
    </div>

    <div class="form-group" id="previewBox" style="display:none; margin-top:10px;">
        <label>Preview</label><br />
        <img id="imagePreview" src="" style="width:200px; height:140px; object-fit:cover;" />
    </div>

    <input type="submit" value="Create" class="btn btn-primary" />
    <a asp-action="Index">Back to List</a>
</form>

@section Scripts {
    <script>
        function previewImage(url) {
            if (url) {
                document.getElementById('imagePreview').src = url;
                document.getElementById('previewBox').style.display = 'block';
            } else {
                document.getElementById('previewBox').style.display = 'none';
            }
        }
        window.onload = function () {
            var url = document.getElementById('imageUrlInput').value;
            if (url) previewImage(url);
        }
    </script>
}
