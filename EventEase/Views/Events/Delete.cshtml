@model EventEase.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<h2>Delete Event</h2>

<p>Are you sure you want to delete this?</p>

<dl class="row">
    <dt class="col-sm-3">Event Name</dt>
    <dd class="col-sm-9">@Model.EventName</dd>

    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>

    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate.ToString("dd MMM yyyy")</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="EventId" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index">Back to List</a>
</form>
