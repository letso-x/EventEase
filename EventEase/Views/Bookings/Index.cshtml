@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h2>Bookings</h2>

<p><a asp-action="Create">Create New</a></p>

<table class="table">
    <thead>
        <tr>
            <th>Venue Image</th>
            <th>Venue</th>
            <th>Event</th>
            <th>Booking Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="@item.Venue?.ImageUrl" alt="@item.Venue?.VenueName" style="width:100px; height:70px; object-fit:cover;" />
                </td>
                <td>@item.Venue?.VenueName</td>
                <td>@item.Event?.EventName</td>
                <td>@item.BookingDate.ToString("dd MMM yyyy")</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookingId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BookingId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BookingId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
