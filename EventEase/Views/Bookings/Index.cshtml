@model EventEase.Models.BookingSearchViewModel

@{
    ViewData["Title"] = "Bookings";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="fas fa-calendar-check"></i> Bookings Management
            </h2>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Create New Booking
            </a>
        </div>
    </div>

    <!-- Search Section -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">
                <i class="fas fa-search"></i> Search Bookings
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
               
                <div class="col-md-4">
                    <label for="bookingId" class="form-label">Booking ID</label>
                    <input type="number" 
                           class="form-control" 
                           id="bookingId" 
                           name="bookingId" 
                           placeholder="e.g., 123"
                           value="@Model.SearchBookingId" />
                </div>
                <div class="col-md-4">
                    <label for="eventName" class="form-label">Event Name</label>
                    <input type="text" 
                           class="form-control" 
                           id="eventName" 
                           name="eventName" 
                           placeholder="Enter event name..."
                           value="@Model.SearchEventName" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-info">
                        <i class="fas fa-search"></i> Search
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-redo"></i> Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    
    @if (Model.Bookings.Count > 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Found <strong>@Model.Bookings.Count</strong> booking(s)
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <text>matching "<strong>@Model.SearchQuery</strong>"</text>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i> No bookings found.
            @if (!string.IsNullOrEmpty(Model.SearchQuery) || Model.SearchBookingId.HasValue || !string.IsNullOrEmpty(Model.SearchEventName))
            {
                <text>Try adjusting your search criteria.</text>
            }
        </div>
    }

 
    @if (Model.Bookings.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th scope="col" style="width: 8%;">Booking ID</th>
                        <th scope="col" style="width: 10%;">Venue Image</th>
                        <th scope="col" style="width: 15%;">Venue</th>
                        <th scope="col" style="width: 15%;">Event</th>
                        <th scope="col" style="width: 12%;">Booking Date</th>
                        <th scope="col" style="width: 10%;">Status</th>
                        <th scope="col" style="width: 20%;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Bookings)
                    {
                        var statusBadgeClass = item.Status switch
                        {
                            "Confirmed" => "badge-success",
                            "Pending" => "badge-warning text-dark",
                            "Cancelled" => "badge-danger",
                            _ => "badge-secondary"
                        };

                        <tr>
                            <td>
                                <span class="badge bg-primary">@item.BookingId</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Venue?.ImageUrl))
                                {
                                    <img src="@item.Venue.ImageUrl" 
                                         alt="@item.Venue?.VenueName" 
                                         class="img-thumbnail rounded"
                                         style="width:80px; height:60px; object-fit:cover;" 
                                         onerror="this.src='https://placehold.co/80x60?text=No+Image'" />
                                }
                                else
                                {
                                    <span class="text-muted small">No image</span>
                                }
                            </td>
                            <td>
                                <strong>@item.Venue?.VenueName</strong>
                                <br />
                                <small class="text-muted">@item.Venue?.Location</small>
                            </td>
                            <td>
                                <strong>@item.Event?.EventName</strong>
                                <br />
                                <small class="text-muted">
                                    @if (item.Event?.StartDate != default(DateTime))
                                    {
                                        @item.Event?.StartDate.ToString("dd MMM yyyy")
                                    }
                                </small>
                            </td>
                            <td>
                                <span class="badge bg-info text-dark">
                                    @item.BookingDate.ToString("dd MMM yyyy")
                                </span>
                            </td>
                            <td>
                                <span class="badge @statusBadgeClass">
                                    @item.Status
                                </span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@item.BookingId" class="btn btn-sm btn-info" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.BookingId" class="btn btn-sm btn-warning" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.BookingId" class="btn btn-sm btn-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
}
