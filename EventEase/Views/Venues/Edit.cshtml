@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Edit Venue";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h2 class="mb-4">
                <i class="fas fa-edit"></i> Edit Venue
            </h2>

            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="VenueId" />

                <div class="mb-3">
                    <label asp-for="VenueName" class="form-label"></label>
                    <input asp-for="VenueName" class="form-control" placeholder="Enter venue name" />
                    <span asp-validation-for="VenueName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location" class="form-control" placeholder="Enter location" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Capacity" class="form-label"></label>
                    <input asp-for="Capacity" class="form-control" type="number" placeholder="e.g., 500" />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>

                <!-- Image URL Option -->
                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label">Image URL</label>
                    <input asp-for="ImageUrl"
                           class="form-control"
                           id="imageUrlInput"
                           placeholder="Paste any image URL here..."
                           oninput="previewFromUrl(this.value)" />
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    <small class="form-text text-muted">Or upload a new file below to store in Azure</small>
                </div>

                <!-- File Upload Option -->
                <div class="mb-3">
                    <label for="imageFile" class="form-label">Upload New Image (Optional)</label>
                    <input type="file" 
                           name="imageFile" 
                           id="imageFile" 
                           class="form-control" 
                           accept="image/*"
                           onchange="previewFromFile(this)" />
                    <small class="form-text text-muted">Max file size: 10MB. Supported formats: JPG, PNG, GIF, WebP</small>
                </div>

                <!-- Current/Preview Image -->
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-3" id="previewContainer">
                        <label class="form-label">Current Image</label>
                        <img id="imagePreview"
                             src="@Model.ImageUrl"
                             alt="Image preview"
                             class="img-thumbnail rounded"
                             style="max-height: 220px; width: 100%; object-fit: cover;"
                             onerror="this.onerror=null; document.getElementById('previewError').style.display='block'; this.style.display='none';" />
                        <div id="previewError" class="alert alert-warning mt-2" style="display:none;">
                            <i class="fas fa-exclamation-triangle"></i> Could not load image. Check the URL is correct and publicly accessible.
                        </div>
                    </div>
                }

                <div class="mb-3 form-check">
                    <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                    <label asp-for="IsAvailable" class="form-check-label">Available for Booking</label>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-save"></i> Update Venue
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewFromUrl(url) {
            const container = document.getElementById('previewContainer');
            if (!container) {
                // Create the container if it doesn't exist
                const form = document.querySelector('form');
                const div = document.createElement('div');
                div.id = 'previewContainer';
                div.className = 'mb-3';
                div.innerHTML = '<label class="form-label">Image Preview</label><img id="imagePreview" class="img-thumbnail rounded" style="max-height: 220px; width: 100%; object-fit: cover;"/><div id="previewError" class="alert alert-warning mt-2" style="display:none;"><i class="fas fa-exclamation-triangle"></i> Could not load image.</div>';
                form.appendChild(div);
            }

            const img = document.getElementById('imagePreview');
            const err = document.getElementById('previewError');

            if (!url || url.trim() === '') {
                document.getElementById('previewContainer').style.display = 'none';
                return;
            }

            err.style.display = 'none';
            img.style.display = 'block';
            img.src = url;
            document.getElementById('previewContainer').style.display = 'block';
            // Clear file input if URL is provided
            document.getElementById('imageFile').value = '';
        }

        function previewFromFile(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    let container = document.getElementById('previewContainer');
                    if (!container) {
                        const form = document.querySelector('form');
                        container = document.createElement('div');
                        container.id = 'previewContainer';
                        container.className = 'mb-3';
                        container.innerHTML = '<label class="form-label">Image Preview</label><img id="imagePreview" class="img-thumbnail rounded" style="max-height: 220px; width: 100%; object-fit: cover;"/>';
                        form.appendChild(container);
                    }
                    document.getElementById('imagePreview').src = e.target.result;
                    container.style.display = 'block';
                    // Clear URL input if file is selected
                    document.getElementById('imageUrlInput').value = '';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Show existing image on load
        window.addEventListener('load', function () {
            const input = document.getElementById('imageUrlInput');
            if (input.value && input.value.trim() !== '') {
                const container = document.getElementById('previewContainer');
                if (container) {
                    container.style.display = 'block';
                }
            }
        });
    </script>
}
