@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<div class="row">
    <div class="col-md-7">
        <!-- Hero image -->
        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://placehold.co/800x400?text=No+Image" : Model.ImageUrl)"
             alt="@Model.VenueName"
             class="img-fluid rounded mb-4 w-100"
             style="max-height: 350px; object-fit: cover;"
             onerror="this.onerror=null;this.src='https://placehold.co/800x400?text=No+Image';" />

        <h2>@Model.VenueName</h2>
        <p class="text-muted">📍 @Model.Location</p>
        <hr />

        <dl class="row">
            <dt class="col-sm-4">Capacity</dt>
            <dd class="col-sm-8">@Model.Capacity people</dd>

            <dt class="col-sm-4">Availability</dt>
            <dd class="col-sm-8">
                <span class="badge @(Model.IsAvailable ? "bg-success" : "bg-secondary") fs-6">
                    @(Model.IsAvailable ? "Available" : "Unavailable")
                </span>
            </dd>

            <dt class="col-sm-4">Image URL</dt>
            <dd class="col-sm-8">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <a href="@Model.ImageUrl" target="_blank" class="text-truncate d-inline-block" style="max-width:300px;">
                        @Model.ImageUrl
                    </a>
                }
                else
                {
                    <span class="text-muted">No image set</span>
                }
            </dd>
        </dl>

        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-warning">Edit Venue</a>
            <a asp-action="Index" class="btn btn-secondary">Back to Venues</a>
        </div>
    </div>
</div>
